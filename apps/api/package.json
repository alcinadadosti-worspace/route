{
  "name": "@rota/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/servidor.ts",
    "start": "node --import tsx src/servidor.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "criar-usuario": "node --import tsx scripts/criar-usuario.ts",
    "cadastrar-cd": "node --import tsx scripts/cadastrar-cd.ts",
    "publicar-rules": "node --import tsx scripts/publicar-rules.ts",
    "publicar-mapa": "node --import tsx scripts/publicar-mapa.ts",
    "configurar-cors": "node --import tsx scripts/configurar-cors-storage.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@rota/shared": "*",
    "fast-xml-parser": "^4.5.0",
    "fastify": "^5.1.0",
    "firebase-admin": "^14.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
