rules_version = '2';

// Security rules por papel (seções 2 e 13). Papel vem do custom claim
// aplicado pelo script criar-usuario. Toda escrita de dados de escritório é
// da API (Admin SDK, que não passa por estas regras); os apps escrevem só o
// que nasce em campo, cada escrita limitada aos seus campos: confirmações
// (rotas/pedidos/entregas), pin + dossiê do local (clientes) e o rastro
// bruto da gravação (trilhasBrutas).

service cloud.firestore {
  match /databases/{database}/documents {
    function logado() {
      return request.auth != null;
    }
    function papel() {
      return logado() ? request.auth.token.get('papel', '') : '';
    }
    function escritorio() {
      return papel() == 'admin' || papel() == 'operador';
    }

    // Motorista lê apenas as próprias rotas; escritório lê todas.
    // Em campo (RF-18), o dono da rota atualiza o status das paradas e a
    // conclusão — nada além desses campos.
    match /rotas/{rotaId} {
      allow read: if escritorio() || (logado() && resource.data.motoristaId == request.auth.uid);
      allow update: if logado()
        && resource.data.motoristaId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['paradas', 'status', 'concluidaEm'])
        && request.resource.data.status in ['em_execucao', 'concluida'];
      allow create, delete: if false;
    }

    // Clientes: sem CPF em claro por desenho (hash + máscara); o motorista
    // precisa de nome, contato, endereço, coordenada e observações do local.
    // Em campo ele escreve duas coisas, cada uma restrita aos seus campos:
    // o pin confirmado (RF-07, com autoria dele) e o dossiê do local (RF-21).
    match /clientes/{clienteId} {
      allow read: if logado();
      allow update: if logado() && (
        (request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['coordenada', 'statusMapeamento', 'mapeadoPor', 'mapeadoEm'])
         && request.resource.data.statusMapeamento == 'mapeado'
         && request.resource.data.mapeadoPor == request.auth.uid)
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['fotoReferenciaPath', 'observacoes'])
      );
      allow create, delete: if false;
    }

    // Rastro cru da gravação de trilha (seção 11.1): criado em campo pelo
    // autor, imutável no aparelho — quem o consome e atualiza é a API.
    match /trilhasBrutas/{trilhaBrutaId} {
      allow read: if escritorio();
      allow create: if logado()
        && request.resource.data.gravadaPor == request.auth.uid
        && request.resource.data.status == 'pendente'
        && request.resource.data.keys().hasAll(
             ['clienteId', 'pontos', 'gravadaPor', 'iniciadaEm', 'finalizadaEm', 'status']);
      allow update, delete: if false;
    }

    // Pedidos guardam os valores da nota: leitura restrita ao escritório
    // (seção 13). A confirmação em campo pode escrever SÓ o status — sem
    // permissão de leitura, o motorista nunca vê o documento.
    match /pedidos/{pedidoId} {
      allow read: if escritorio();
      allow update: if logado()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in ['entregue', 'insucesso'];
      allow create, delete: if false;
    }

    match /usuarios/{uid} {
      allow read: if escritorio() || (logado() && request.auth.uid == uid);
      allow write: if false;
    }

    match /config/{docId} {
      allow read: if logado();
      allow write: if false;
    }

    match /trilhas/{trilhaId} {
      allow read: if logado();
      allow write: if false;
    }

    // Registro de entrega/insucesso (seção 7.5): criado em campo, imutável.
    match /entregas/{entregaId} {
      allow read: if escritorio();
      allow create: if logado()
        && request.resource.data.keys().hasAll(
             ['pedidoId', 'rotaId', 'clienteId', 'resultado', 'confirmadaEm'])
        && request.resource.data.resultado in ['entregue', 'ausente', 'nao_localizado', 'recusa'];
      allow update, delete: if false;
    }
  }
}
