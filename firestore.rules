rules_version = '2';

// Security rules por papel (seções 2 e 13). Papel vem do custom claim
// aplicado pelo script criar-usuario. Toda escrita de dados é da API
// (Admin SDK, que não passa por estas regras); os apps só leem — as
// escritas de campo do motorista (confirmações, pins) chegam na Fase 4
// com regras próprias por campo.

service cloud.firestore {
  match /databases/{database}/documents {
    function logado() {
      return request.auth != null;
    }
    function papel() {
      return logado() ? request.auth.token.get('papel', '') : '';
    }
    function escritorio() {
      return papel() == 'admin' || papel() == 'operador';
    }

    // Motorista lê apenas as próprias rotas; escritório lê todas.
    match /rotas/{rotaId} {
      allow read: if escritorio() || (logado() && resource.data.motoristaId == request.auth.uid);
      allow write: if false;
    }

    // Clientes: sem CPF em claro por desenho (hash + máscara); o motorista
    // precisa de nome, contato, endereço, coordenada e observações do local.
    match /clientes/{clienteId} {
      allow read: if logado();
      allow write: if false;
    }

    // Pedidos guardam os valores da nota: restritos ao escritório (seção 13).
    match /pedidos/{pedidoId} {
      allow read: if escritorio();
      allow write: if false;
    }

    match /usuarios/{uid} {
      allow read: if escritorio() || (logado() && request.auth.uid == uid);
      allow write: if false;
    }

    match /config/{docId} {
      allow read: if logado();
      allow write: if false;
    }

    match /trilhas/{trilhaId} {
      allow read: if logado();
      allow write: if false;
    }

    match /entregas/{entregaId} {
      allow read: if escritorio();
      allow write: if false;
    }
  }
}
